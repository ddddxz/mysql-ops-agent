# MySQL Agent 配置示例
# 复制此文件为 .env 并填入实际值

# LLM 配置
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096
LLM_EMBEDDING_MODEL=text-embedding-v3

# MySQL 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
# MYSQL_DATABASE=mysql

# RAG 配置
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=4

# API Key 从环境变量 DASHSCOPE_API_KEY 或 OPENAI_API_KEY 读取
# 设置方式: export DASHSCOPE_API_KEY=your_api_key

# 默认管理员密码（首次初始化时使用）
DEFAULT_ROOT_PASSWORD=your_root_password

# QQ 邮件告警配置（可选）
# 获取方式：QQ邮箱 -> 设置 -> 账户 -> POP3/SMTP服务 -> 开启并获取授权码
QQ_EMAIL=your_qq_email@qq.com
QQ_EMAIL_PASSWORD=your_email_auth_code
ALERT_EMAIL_RECEIVERS=receiver@example.com
